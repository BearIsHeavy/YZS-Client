# ==========================================
# Environment Variables for YanZhuShou Frontend
# ==========================================
# Copy this file to .env and modify as needed
# ==========================================

# Backend API URL
# This is the URL of your FastAPI backend server
VITE_API_URL=http://localhost:8000

# Host port for Docker deployment
# The port on your host machine that maps to container port 80
HOST_PORT=80

# ==========================================
# Examples:
# ==========================================
# 
# Local development:
# VITE_API_URL=http://localhost:8000
# HOST_PORT=80
#
# Production server:
# VITE_API_URL=https://api.your-domain.com
# HOST_PORT=80
#
# Custom port:
# VITE_API_URL=http://192.168.1.100:8000
# HOST_PORT=8080
# ==========================================
